# Google Cloud / Vertex AI
GCP_PROJECT_ID=phrasal-method-484415-g7
GCP_LOCATION=us-west1
GEMINI_MODEL=gemini-2.5-pro

# Dice a google-genai (usato da ADK) di usare Vertex AI invece dell'API Gemini pubblica.
# Senza questo setta "No API key was provided". Di default viene forzato a TRUE
# da app/__init__.py, qui è solo per chiarezza.
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# BigQuery
BQ_DATASET=banca_raw

# GitHub (lettura SQL ETL + apertura PR fix)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=davideconcu-accenture/Agent-GCP-ETL-Code
GITHUB_BRANCH=main

# Firestore
FIRESTORE_COLLECTION=etl_agent_runs
