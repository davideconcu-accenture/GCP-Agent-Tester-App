# Google Cloud / Vertex AI
# us-central1 ha quote Gemini molto più ampie di us-west1 — riduce i 429.
# gemini-2.5-flash è più che sufficiente per tool calling + reasoning su SQL,
# e ha quote ~10x rispetto a Pro. Puoi cambiare in "gemini-2.5-pro" se la tua
# quota lo permette.
GCP_PROJECT_ID=phrasal-method-484415-g7
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Fallback automatico se il modello principale satura (429 RESOURCE_EXHAUSTED)
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Retry policy per 429 (tentativi * base_delay con backoff esponenziale)
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_S=5.0

# Dice a google-genai (usato da ADK) di usare Vertex AI invece dell'API Gemini pubblica.
# Senza questo setta "No API key was provided". Di default viene forzato a TRUE
# da app/__init__.py, qui è solo per chiarezza.
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# BigQuery
BQ_DATASET=banca_raw

# GitHub (lettura SQL ETL + apertura PR fix)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=davideconcu-accenture/Agent-GCP-ETL-Code
GITHUB_BRANCH=main

# Firestore
FIRESTORE_COLLECTION=etl_agent_runs
